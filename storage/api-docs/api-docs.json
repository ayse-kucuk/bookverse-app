        "/posts": {
            "get": {
                "tags": [
                    "Posts"
                ],
                "summary": "Akış (görünür paylaşımlar)",
                "operationId": "cce7863441436fd49dc474491f658292",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paylaşım listesi"
                    }
                }
            },
            "post": {
                "tags": [
                    "Posts"
                ],
                "summary": "Yeni paylaşım oluştur",
                "operationId": "21a6ac5f9280a3cf958c3d066b5600ee",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "content",
                                    "type"
                                ],
                                "properties": {
                                    "content": {
                                        "type": "string",
                                        "example": "Bu kitabı çok beğendim."
                                    },
                                    "type": {
                                        "type": "string",
                                        "example": "thought",
                                        "enum": [
                                            "thought",
                                            "quote"
                                        ]
                                    },
                                    "book_id": {
                                        "type": "integer",
                                        "example": 1,
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Oluşturuldu"
                    },
                    "401": {
                        "description": "Yetkisiz"
                    },
                    "422": {
                        "description": "Doğrulama hatası"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
